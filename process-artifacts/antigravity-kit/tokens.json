{
  "_meta": {
    "source": "https://antigravity.google/",
    "extracted": "2026-07-11",
    "note": "Read verbatim from production CSS (styles-NNWH23TG.css, 204 :root vars) + live computed styles. Values are exact — do not round. For LUMA, the ONLY intended override is the accent ink (see `accent` block): Antigravity uses Google-blue as its one accent; LUMA uses signature yellow. Everything else — type scale, spacing, radius, easing, layout — is preserved."
  },

  "font": {
    "family_source": "\"Google Sans Flex\", \"Google Sans\", sans-serif",
    "family_substitute": "\"Roboto Flex\", \"Google Sans Flex\", sans-serif",
    "substitute_note": "Google Sans Flex is proprietary (not on Google Fonts). Roboto Flex is its public sibling and carries the SAME axes — opsz 8–144, wght 100–1000, wdth 25–151. It preserves all three artistic decisions. Import it, not a static font.",
    "variable_axes": { "opsz": "8..144", "wght": "100..1000 (source uses 450)", "wdth": "25..151 (source uses 100)" },
    "mono": "\"Google Sans Code\", ui-monospace, monospace",
    "icons": "\"Google Symbols\" (substitute: Material Symbols Rounded)"
  },

  "accent": {
    "_comment": "LUMA override — the single ink color per screen. Replaces Antigravity's --palette-blue-600.",
    "--accent": "#FFC400",
    "--accent-strong": "#F0A800",
    "--accent-soft": "#FFF3C9",
    "--accent-ink-on": "#121317",
    "source_accent_was": "#3279F9"
  },

  "palette": {
    "--palette-grey-0": "#FFFFFF",
    "--palette-grey-10": "#F8F9FC",
    "--palette-grey-15": "#F0F1F5",
    "--palette-grey-20": "#EFF2F7",
    "--palette-grey-50": "#E6EAF0",
    "--palette-grey-100": "#E1E6EC",
    "--palette-grey-200": "#CDD4DC",
    "--palette-grey-300": "#B2BBC5",
    "--palette-grey-400": "#B7BFD9",
    "--palette-grey-800": "#45474D",
    "--palette-grey-900": "#2F3034",
    "--palette-grey-1000": "#212226",
    "--palette-grey-1100": "#18191D",
    "--palette-grey-1200": "#121317",
    "--surface": "#FFFFFF",
    "--surface-container": "#F8F9FC",
    "--surface-container-high": "#EFF2F7",
    "--on-surface": "#121317",
    "--on-surface-variant": "#45474D",
    "--dark-surface": "#121317",
    "--on-dark": "#F8F9FC",
    "--outline": "rgba(33, 34, 38, .12)",
    "--outline-variant": "rgba(33, 34, 38, .06)",
    "--outline-on-dark": "rgba(230, 234, 240, .12)"
  },

  "type_scale_px": {
    "_note": "size / line-height / letter-spacing — all in px (line-heights are px, never ratios). opsz axis = matches px size, capped at 144 for the biggest display cuts.",
    "landing-main": { "size": "107px", "line": "107px", "tracking": "-2.14px", "opsz": 144, "weight": 450 },
    "heading-00 (9xl)": { "size": "148px", "line": "145.04px", "tracking": "-2.96px", "opsz": 144, "weight": 450 },
    "heading-0 (8xl)":  { "size": "124px", "line": "121.52px", "tracking": "-2.48px", "opsz": 124, "weight": 450 },
    "heading-1 (7xl)":  { "size": "98px",  "line": "82.04px",  "tracking": "-1.8px",  "opsz": 98,  "weight": 450 },
    "heading-2 (6xl)":  { "size": "72px",  "line": "72px",     "tracking": "-1.44px", "opsz": 72,  "weight": 450 },
    "heading-3 (5xl)":  { "size": "54px",  "line": "56.16px",  "tracking": "-.95px",  "opsz": 54,  "weight": 450 },
    "heading-4 (4xl)":  { "size": "42px",  "line": "43.68px",  "tracking": "-.73px",  "opsz": 42,  "weight": 450 },
    "heading-5 (3xl)":  { "size": "32px",  "line": "33.92px",  "tracking": "-.15px",  "opsz": 32,  "weight": 450 },
    "heading-6 (2xl)":  { "size": "28px",  "line": "30.24px",  "tracking": "-.1px",   "opsz": 28,  "weight": 450 },
    "heading-7 (xl)":   { "size": "24px",  "line": "25.92px",  "tracking": "-.07px",  "opsz": 24,  "weight": 450 },
    "heading-8 (lg)":   { "size": "22px",  "line": "24.64px",  "tracking": "-.08px",  "opsz": 22,  "weight": 450 },
    "heading-9 (md)":   { "size": "20px",  "line": "26px",     "tracking": "-.05px",  "opsz": 20,  "weight": 450 },
    "body-base":        { "size": "17.5px","line": "25.38px",  "tracking": ".18px",   "opsz": 17.5,"weight": 400 },
    "body-sm":          { "size": "14.5px","line": "21.02px",  "tracking": ".16px",   "opsz": 14.5,"weight": 400 },
    "body-xs":          { "size": "12.5px","line": "15.5px",   "tracking": ".11px",   "opsz": 12.5,"weight": 400 },
    "cta":              { "size": "17.5px","line": "25.38px",  "tracking": ".18px",   "opsz": 17.5,"weight": 450 },
    "cta-sm":           { "size": "14.5px","line": "21.02px",  "tracking": ".11px",   "opsz": 14.5,"weight": 450 }
  },

  "spacing": {
    "--space-none": "0px", "--space-xs": "4px", "--space-sm": "8px", "--space-md": "16px",
    "--space-lg": "24px", "--space-xl": "36px", "--space-2xl": "48px", "--space-3xl": "60px",
    "--space-4xl": "80px", "--space-5xl": "88px", "--space-6xl": "120px", "--space-7xl": "180px"
  },

  "radius": {
    "--shape-corner-xs": "4px", "--shape-corner-sm": "8px", "--shape-corner-md": "16px",
    "--shape-corner-lg": "24px", "--shape-corner-xl": "36px", "--shape-corner-2xl": "48px",
    "--shape-corner-rounded": "9999px"
  },

  "easing": {
    "--ease-out-expo": "cubic-bezier(.19, 1, .22, 1)",
    "--ease-out-quint": "cubic-bezier(.23, 1, .32, 1)",
    "--ease-out-circ": "cubic-bezier(.075, .82, .165, 1)",
    "--ease-out-back": "cubic-bezier(.34, 1.85, .64, 1)",
    "--ease-in-out-quart": "cubic-bezier(.77, 0, .175, 1)",
    "--ease-in-out-expo": "cubic-bezier(1, 0, 0, 1)",
    "--ease-in-out-cubic": "cubic-bezier(.645, .045, .355, 1)"
  },

  "layout": {
    "--nav-height": "52px",
    "--page-margin": "72px",
    "--grid-columns": "12",
    "--grid-gutter": "64px",
    "--grid-gutter-sm": "56px",
    "--container-max": "calc(1728px + var(--page-margin) * 2)",
    "--section-pad-y": "120px"
  },

  "breakpoints": {
    "--breakpoint-xs": "425px",
    "--breakpoint-sm": "767px",
    "--breakpoint-md": "1024px",
    "--breakpoint-lg": "1440px",
    "--breakpoint-max": "1600px"
  }
}
